# Cross-Project Brain example environment

export CPB_PROJECT_ID="example-project"
export CPB_OPERATOR="your-github-username"

# Recommended real-world layout:
# - keep team code in the current repo
# - keep your cross-project memory and personal career docs in a separate private GitHub repo checkout
# - keep machine-only state local
# - recommended private GitHub repo name: <github-username>/cpb-personal

# Example personal private repo checkout
# export CPB_PERSONAL_REPO="$HOME/workspace/cross-project-brain-personal"
# Personal GitHub repo creation mode: ask | never | always
# export CPB_CREATE_PERSONAL_REMOTE="ask"

# Optional overrides
# export CPB_REPO_ROOT="/absolute/path/to/repo"
# export CPB_AGENT_ROOT="$CPB_REPO_ROOT/.agent/cross-project-brain/$CPB_PROJECT_ID"
# If CPB_PERSONAL_REPO is set, CPB_GLOBAL_BRAIN and CPB_CAREER_DOCS_ROOT can be derived automatically.
# export CPB_GLOBAL_BRAIN="$CPB_PERSONAL_REPO/brains/global-operators/$CPB_OPERATOR/brain_v4"
# export CPB_TEAM_BRAIN="$CPB_REPO_ROOT/brains/team-brain/brain_v4"
# For shared/team repos, consider keeping project brain local-only instead of tracked:
# export CPB_PROJECT_BRAIN="$CPB_AGENT_ROOT/project-brain/brain_v4"
# export CPB_RUNTIME_BRAIN="$CPB_AGENT_ROOT/runtime-brain/brain_v4"
# export CPB_CAREER_DOCS_ROOT="$CPB_PERSONAL_REPO/docs/career/operators/$CPB_OPERATOR"

# Language defaults
# export CPB_SHARED_LANGUAGE="en"
# export CPB_PERSONAL_LANGUAGE="ko"
# export CPB_HIRING_LANGUAGE="ko"
